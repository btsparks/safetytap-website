---
import Base from '../layouts/Base.astro';
---

<Base
  title="Try SafetyTAP"
  metaTitle="Try SafetyTAP — Get a Safety Observation in Seconds"
  description="Upload a jobsite photo and get one specific safety observation back in seconds. The same AI-powered hazard recognition tool used by construction crews."
>

  <!-- Hero -->
  <section class="relative bg-navy-deep py-16 md:py-20 overflow-hidden text-white">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep via-navy to-navy-mid opacity-100 pointer-events-none"></div>
    <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-teal/10 blur-3xl pointer-events-none"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-extrabold leading-tight tracking-tight">Try SafetyTAP</h1>
      <p class="mt-4 text-lg text-white/80 leading-relaxed max-w-xl mx-auto">Upload a jobsite photo and get one specific safety observation back — the kind an experienced pro would make standing next to you.</p>
    </div>
  </section>

  <!-- Upload / Result Area -->
  <section class="py-12 md:py-16 bg-light">
    <div class="max-w-2xl mx-auto px-6">

      <!-- Drop Zone (initial state) -->
      <div id="drop-zone"
           class="relative border-2 border-dashed border-gray-300 rounded-2xl p-12 text-center
                  bg-white hover:border-teal/50 hover:bg-teal/[0.02] transition-all duration-200 cursor-pointer"
           role="button" tabindex="0" aria-label="Upload a photo">
        <div class="pointer-events-none">
          <svg class="mx-auto w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="mt-4 text-dark/70 text-base">Drag a construction photo here</p>
          <p class="mt-1 text-dark/50 text-sm">or</p>
          <button id="choose-btn"
                  class="mt-3 inline-flex items-center gap-2 bg-teal hover:bg-teal-light text-white font-semibold
                         text-sm px-6 py-2.5 rounded-lg shadow-sm shadow-teal/20
                         transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md pointer-events-auto">
            Choose Photo
          </button>
          <p class="mt-3 text-dark/40 text-xs">JPEG, PNG, or WebP up to 5MB</p>
        </div>
        <input id="file-input" type="file" accept="image/*" capture="environment" class="hidden" />
      </div>

      <!-- Preview state (hidden initially) -->
      <div id="preview-area" class="hidden">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="p-6">
            <div class="flex items-start gap-4">
              <img id="preview-img" src="" alt="Uploaded photo preview"
                   class="w-28 h-28 object-cover rounded-lg border border-gray-200 flex-shrink-0" />
              <div class="flex-1 min-w-0">
                <p id="file-name" class="text-sm text-dark/70 truncate"></p>
                <p id="file-size" class="text-xs text-dark/40 mt-0.5"></p>
                <input id="caption-input" type="text" placeholder="Optional: describe the task (e.g. setting rebar on grade)"
                       class="mt-3 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-dark
                              placeholder:text-dark/40 focus:outline-none focus:border-teal focus:ring-1 focus:ring-teal/30" />
              </div>
            </div>
            <div class="mt-5 flex items-center gap-3">
              <button id="observe-btn"
                      class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light text-white font-semibold
                             text-sm px-6 py-2.5 rounded-lg shadow-sm shadow-teal/20
                             transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
                Get Observation
              </button>
              <button id="change-btn"
                      class="text-sm text-dark/50 hover:text-dark/80 transition-colors">
                Change photo
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Processing indicator (hidden initially) -->
      <div id="processing" class="hidden mt-6">
        <div class="flex items-center gap-3 justify-center py-4">
          <div class="flex gap-1.5">
            <span class="w-2 h-2 bg-teal rounded-full animate-bounce-dot"></span>
            <span class="w-2 h-2 bg-teal rounded-full animate-bounce-dot" style="animation-delay: 0.15s"></span>
            <span class="w-2 h-2 bg-teal rounded-full animate-bounce-dot" style="animation-delay: 0.3s"></span>
          </div>
          <p class="text-dark/60 text-sm">Analyzing your photo...</p>
        </div>
      </div>

      <!-- Result card (hidden initially) -->
      <div id="result-area" class="hidden mt-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden border-l-4 border-l-teal">
          <div class="p-6">
            <p id="result-observation" class="text-dark text-base leading-relaxed"></p>
            <p id="result-takeaway" class="mt-3 text-dark/50 text-sm"></p>
          </div>
        </div>
        <div class="mt-5 flex items-center gap-4">
          <button id="try-another-btn"
                  class="inline-flex items-center gap-2 border border-gray-300 hover:border-gray-400
                         text-dark/70 hover:text-dark font-medium text-sm px-5 py-2.5 rounded-lg
                         transition-all duration-200 hover:bg-gray-50">
            Try Another Photo
          </button>
          <a href="/contact"
             class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light text-white font-semibold
                    text-sm px-5 py-2.5 rounded-lg shadow-sm shadow-teal/20
                    transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            Request a Demo
          </a>
        </div>
      </div>

      <!-- Error card (hidden initially) -->
      <div id="error-area" class="hidden mt-6">
        <div class="bg-warm/5 rounded-2xl border border-warm/20 overflow-hidden">
          <div class="p-6">
            <p id="error-message" class="text-dark text-sm"></p>
          </div>
        </div>
        <div class="mt-4">
          <button id="error-retry-btn"
                  class="inline-flex items-center gap-2 border border-gray-300 hover:border-gray-400
                         text-dark/70 hover:text-dark font-medium text-sm px-5 py-2.5 rounded-lg
                         transition-all duration-200 hover:bg-gray-50">
            Try Again
          </button>
        </div>
      </div>

      <!-- Privacy note -->
      <p class="mt-6 text-center text-dark/40 text-xs">Your photo is analyzed and immediately discarded. Nothing is stored.</p>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="relative py-20 md:py-28 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep via-navy to-navy-mid pointer-events-none"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-teal mb-3">Ready to Scale?</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold leading-tight tracking-tight">Give your entire crew this capability.</h2>
      <p class="mt-4 text-lg text-white/80 leading-relaxed max-w-xl mx-auto">SafetyTAP works over Telegram — no app to download, no training required. Your crew texts a photo, gets an observation back. That simple.</p>
      <div class="mt-8">
        <a href="/contact"
           class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light
                  text-white font-semibold text-base
                  px-7 py-3.5 rounded-lg
                  shadow-lg shadow-teal/20
                  transition-all duration-200 hover:shadow-xl hover:shadow-teal/30 hover:-translate-y-0.5">
          Request a Demo
        </a>
      </div>
    </div>
  </section>

</Base>

<script>
  const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB

  // Elements
  const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const chooseBtn = document.getElementById('choose-btn') as HTMLButtonElement;
  const previewArea = document.getElementById('preview-area') as HTMLDivElement;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const fileName = document.getElementById('file-name') as HTMLParagraphElement;
  const fileSize = document.getElementById('file-size') as HTMLParagraphElement;
  const captionInput = document.getElementById('caption-input') as HTMLInputElement;
  const observeBtn = document.getElementById('observe-btn') as HTMLButtonElement;
  const changeBtn = document.getElementById('change-btn') as HTMLButtonElement;
  const processing = document.getElementById('processing') as HTMLDivElement;
  const resultArea = document.getElementById('result-area') as HTMLDivElement;
  const resultObservation = document.getElementById('result-observation') as HTMLParagraphElement;
  const resultTakeaway = document.getElementById('result-takeaway') as HTMLParagraphElement;
  const tryAnotherBtn = document.getElementById('try-another-btn') as HTMLButtonElement;
  const errorArea = document.getElementById('error-area') as HTMLDivElement;
  const errorMessage = document.getElementById('error-message') as HTMLParagraphElement;
  const errorRetryBtn = document.getElementById('error-retry-btn') as HTMLButtonElement;

  let currentFile: File | null = null;
  let currentBase64 = '';
  let currentMediaType = '';

  // --- Utility ---
  function formatBytes(bytes: number): string {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function showError(msg: string) {
    errorMessage.textContent = msg;
    errorArea.classList.remove('hidden');
  }

  function resetToInitial() {
    currentFile = null;
    currentBase64 = '';
    currentMediaType = '';
    fileInput.value = '';
    captionInput.value = '';
    dropZone.classList.remove('hidden');
    previewArea.classList.add('hidden');
    processing.classList.add('hidden');
    resultArea.classList.add('hidden');
    errorArea.classList.add('hidden');
  }

  // --- File handling ---
  function handleFile(file: File) {
    // Validate type
    if (!file.type.startsWith('image/')) {
      showError('Please select an image file (JPEG, PNG, or WebP).');
      return;
    }

    const allowed = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
    if (!allowed.includes(file.type)) {
      showError('Unsupported format. Please use JPEG, PNG, or WebP.');
      return;
    }

    // Validate size
    if (file.size > MAX_FILE_SIZE) {
      showError(`That photo is ${formatBytes(file.size)} — please use one under 5MB.`);
      return;
    }

    errorArea.classList.add('hidden');
    currentFile = file;
    currentMediaType = file.type;

    // Read as base64
    const reader = new FileReader();
    reader.onload = (e) => {
      const dataUrl = e.target?.result as string;
      // Strip the data:image/xxx;base64, prefix
      currentBase64 = dataUrl.split(',')[1];

      // Show preview
      previewImg.src = dataUrl;
      fileName.textContent = file.name;
      fileSize.textContent = formatBytes(file.size);
      dropZone.classList.add('hidden');
      previewArea.classList.remove('hidden');
      resultArea.classList.add('hidden');
    };
    reader.readAsDataURL(file);
  }

  // --- Drop zone events ---
  chooseBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    fileInput.click();
  });

  dropZone.addEventListener('click', () => {
    fileInput.click();
  });

  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) handleFile(file);
  });

  // Drag and drop
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-teal', 'bg-teal/[0.04]');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-teal', 'bg-teal/[0.04]');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-teal', 'bg-teal/[0.04]');
    const file = e.dataTransfer?.files?.[0];
    if (file) handleFile(file);
  });

  // --- Change photo ---
  changeBtn.addEventListener('click', () => {
    resetToInitial();
  });

  // --- Get Observation ---
  observeBtn.addEventListener('click', async () => {
    if (!currentBase64 || !currentMediaType) return;

    // Hide preview actions, show processing
    observeBtn.classList.add('hidden');
    changeBtn.classList.add('hidden');
    processing.classList.remove('hidden');
    errorArea.classList.add('hidden');
    resultArea.classList.add('hidden');

    try {
      const res = await fetch('/api/observe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          image: currentBase64,
          mediaType: currentMediaType,
          caption: captionInput.value.trim() || undefined,
        }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Something went wrong.');
      }

      // Parse observation and takeaway tag
      // The takeaway is the last line, separated by a blank line
      const text: string = data.observation || '';
      const parts = text.split(/\n\n/);
      let observation = text;
      let takeaway = '';

      if (parts.length >= 2) {
        // Last part is the takeaway tag
        takeaway = parts[parts.length - 1].trim();
        observation = parts.slice(0, -1).join('\n\n').trim();
      }

      resultObservation.textContent = observation;
      resultTakeaway.textContent = takeaway;
      resultTakeaway.classList.toggle('hidden', !takeaway);

      processing.classList.add('hidden');
      resultArea.classList.remove('hidden');
    } catch (err: any) {
      processing.classList.add('hidden');
      observeBtn.classList.remove('hidden');
      changeBtn.classList.remove('hidden');
      showError(err.message || 'Something went wrong. Please try again.');
    }
  });

  // --- Try Another ---
  tryAnotherBtn.addEventListener('click', () => {
    resetToInitial();
  });

  // --- Error retry ---
  errorRetryBtn.addEventListener('click', () => {
    errorArea.classList.add('hidden');
    if (currentBase64) {
      // Re-show the preview so they can try again
      observeBtn.classList.remove('hidden');
      changeBtn.classList.remove('hidden');
    } else {
      resetToInitial();
    }
  });
</script>
