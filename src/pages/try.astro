---
import Base from '../layouts/Base.astro';

const samples = [
  { src: '/images/try/scaffolding.jpg', label: 'Scaffolding' },
  { src: '/images/try/construction-site.jpg', label: 'Active Site' },
  { src: '/images/try/rebar.jpg', label: 'Rebar Work' },
  { src: '/images/try/excavation.jpg', label: 'Excavation' },
];
---

<Base
  title="Try SafetyTAP"
  metaTitle="Try SafetyTAP Free — Instant Hazard Recognition"
  description="Tap a photo, get a safety observation in seconds. Try SafetyTAP free — the same AI-powered hazard recognition tool used by construction crews."
>

  <!-- Hero -->
  <section class="relative bg-navy-deep py-16 md:py-20 overflow-hidden text-white">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep via-navy to-navy-mid opacity-100 pointer-events-none"></div>
    <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-teal/10 blur-3xl pointer-events-none"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-extrabold leading-tight tracking-tight">Try SafetyTAP</h1>
      <p class="mt-4 text-lg text-white/80 leading-relaxed max-w-xl mx-auto">Tap any photo below and get one specific safety observation back — the kind an experienced pro would make standing next to you.</p>
    </div>
  </section>

  <!-- Sample Photos -->
  <section class="py-12 md:py-16 bg-light">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-sm font-semibold tracking-widest uppercase text-teal mb-6 text-center">Pick a Scene</p>
      <div id="photo-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {samples.map((s, i) => (
          <button
            class="sample-photo group relative rounded-xl overflow-hidden shadow-sm hover:shadow-lg
                   transition-all duration-300 hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-teal/50
                   aspect-[4/3]"
            data-src={s.src}
            data-label={s.label}
            data-index={i}
          >
            <img src={s.src} alt={s.label} class="w-full h-full object-cover" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            <span class="absolute bottom-2 left-3 text-white text-sm font-medium">{s.label}</span>
            <div class="absolute inset-0 bg-teal/0 group-hover:bg-teal/10 transition-colors duration-300"></div>
          </button>
        ))}
      </div>

      <!-- Selected photo + result area -->
      <div id="active-area" class="hidden mt-8">
        <!-- Selected photo display -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <img id="active-img" src="" alt="Selected photo" class="w-full max-h-[400px] object-cover" />
        </div>

        <!-- Processing indicator -->
        <div id="processing" class="hidden mt-6">
          <div class="flex items-center gap-3 justify-center py-4">
            <div class="flex gap-1.5">
              <span class="w-2 h-2 bg-teal rounded-full animate-bounce-dot"></span>
              <span class="w-2 h-2 bg-teal rounded-full animate-bounce-dot" style="animation-delay: 0.15s"></span>
              <span class="w-2 h-2 bg-teal rounded-full animate-bounce-dot" style="animation-delay: 0.3s"></span>
            </div>
            <p class="text-dark/60 text-sm">Analyzing...</p>
          </div>
        </div>

        <!-- Result card -->
        <div id="result-area" class="hidden mt-6">
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden border-l-4 border-l-teal">
            <div class="p-6">
              <p id="result-observation" class="text-dark text-base leading-relaxed"></p>
              <p id="result-takeaway" class="mt-3 text-dark/50 text-sm"></p>
            </div>
          </div>
          <div class="mt-5 flex items-center gap-4 flex-wrap">
            <button id="try-another-btn"
                    class="inline-flex items-center gap-2 border border-gray-300 hover:border-gray-400
                           text-dark/70 hover:text-dark font-medium text-sm px-5 py-2.5 rounded-lg
                           transition-all duration-200 hover:bg-gray-50">
              Try Another
            </button>
            <button id="same-photo-btn"
                    class="inline-flex items-center gap-2 border border-teal/30 hover:border-teal
                           text-teal hover:text-teal-light font-medium text-sm px-5 py-2.5 rounded-lg
                           transition-all duration-200 hover:bg-teal/[0.04]">
              Same Photo, New Observation
            </button>
          </div>
        </div>

        <!-- Error card -->
        <div id="error-area" class="hidden mt-6">
          <div class="bg-warm/5 rounded-2xl border border-warm/20 overflow-hidden">
            <div class="p-6">
              <p id="error-message" class="text-dark text-sm"></p>
            </div>
          </div>
          <div class="mt-4">
            <button id="error-retry-btn"
                    class="inline-flex items-center gap-2 border border-gray-300 hover:border-gray-400
                           text-dark/70 hover:text-dark font-medium text-sm px-5 py-2.5 rounded-lg
                           transition-all duration-200 hover:bg-gray-50">
              Try Again
            </button>
          </div>
        </div>
      </div>

      <!-- Privacy note -->
      <p class="mt-8 text-center text-dark/40 text-xs">Your photo is analyzed and immediately discarded. Nothing is stored.</p>
    </div>
  </section>

  <!-- Use It On Your Phone -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-teal mb-3">On Your Phone?</p>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-navy leading-tight tracking-tight">Use SafetyTAP from the job site.</h2>
      <p class="mt-4 text-dark/70 text-base leading-relaxed max-w-lg mx-auto">Open SafetyTAP on Telegram, snap a photo of your work area, and get an observation back in seconds. No app to download. No account to create.</p>
      <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://t.me/SafetyTAP_bot"
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex items-center gap-2 bg-[#2AABEE] hover:bg-[#229ED9] text-white font-semibold
                  text-base px-7 py-3.5 rounded-lg shadow-lg shadow-[#2AABEE]/20
                  transition-all duration-200 hover:shadow-xl hover:-translate-y-0.5">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Open on Telegram
        </a>
        <span class="text-dark/40 text-sm">Free. No sign-up required.</span>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="relative py-20 md:py-28 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep via-navy to-navy-mid pointer-events-none"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-teal mb-3">For Safety Teams</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold leading-tight tracking-tight">Want this for your entire crew?</h2>
      <p class="mt-4 text-lg text-white/80 leading-relaxed max-w-xl mx-auto">SafetyTAP builds hazard recognition skills across your workforce — one observation at a time. Talk to us about rolling it out to your team.</p>
      <div class="mt-8">
        <a href="/contact"
           class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light
                  text-white font-semibold text-base
                  px-7 py-3.5 rounded-lg
                  shadow-lg shadow-teal/20
                  transition-all duration-200 hover:shadow-xl hover:shadow-teal/30 hover:-translate-y-0.5">
          Request a Demo
        </a>
      </div>
    </div>
  </section>

</Base>

<script>
  const activeArea = document.getElementById('active-area') as HTMLDivElement;
  const activeImg = document.getElementById('active-img') as HTMLImageElement;
  const processing = document.getElementById('processing') as HTMLDivElement;
  const resultArea = document.getElementById('result-area') as HTMLDivElement;
  const resultObservation = document.getElementById('result-observation') as HTMLParagraphElement;
  const resultTakeaway = document.getElementById('result-takeaway') as HTMLParagraphElement;
  const tryAnotherBtn = document.getElementById('try-another-btn') as HTMLButtonElement;
  const samePhotoBtn = document.getElementById('same-photo-btn') as HTMLButtonElement;
  const errorArea = document.getElementById('error-area') as HTMLDivElement;
  const errorMessage = document.getElementById('error-message') as HTMLParagraphElement;
  const errorRetryBtn = document.getElementById('error-retry-btn') as HTMLButtonElement;
  const photoGrid = document.getElementById('photo-grid') as HTMLDivElement;

  let currentBase64 = '';
  let currentMediaType = 'image/jpeg';
  let currentSrc = '';

  function resetToGrid() {
    currentBase64 = '';
    currentSrc = '';
    activeArea.classList.add('hidden');
    processing.classList.add('hidden');
    resultArea.classList.add('hidden');
    errorArea.classList.add('hidden');
    // Re-enable all photo buttons
    photoGrid.querySelectorAll('.sample-photo').forEach(btn => {
      (btn as HTMLButtonElement).disabled = false;
      btn.classList.remove('ring-2', 'ring-teal', 'ring-offset-2');
    });
  }

  async function fetchImageAsBase64(src: string): Promise<string> {
    const res = await fetch(src);
    const blob = await res.blob();
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const dataUrl = reader.result as string;
        resolve(dataUrl.split(',')[1]);
      };
      reader.onerror = reject;
      reader.readAsDataURL(blob);
    });
  }

  async function analyzePhoto() {
    processing.classList.remove('hidden');
    resultArea.classList.add('hidden');
    errorArea.classList.add('hidden');

    try {
      // Fetch and encode if we haven't already (or re-encode for same photo)
      if (!currentBase64) {
        currentBase64 = await fetchImageAsBase64(currentSrc);
      }

      const res = await fetch('/api/observe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          image: currentBase64,
          mediaType: currentMediaType,
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Something went wrong.');

      // Parse observation and takeaway tag (separated by double newline)
      const text: string = data.observation || '';
      const parts = text.split(/\n\n/);
      let observation = text;
      let takeaway = '';

      if (parts.length >= 2) {
        takeaway = parts[parts.length - 1].trim();
        observation = parts.slice(0, -1).join('\n\n').trim();
      }

      resultObservation.textContent = observation;
      resultTakeaway.textContent = takeaway;
      resultTakeaway.classList.toggle('hidden', !takeaway);

      processing.classList.add('hidden');
      resultArea.classList.remove('hidden');
    } catch (err: any) {
      processing.classList.add('hidden');
      errorMessage.textContent = err.message || 'Something went wrong. Please try again.';
      errorArea.classList.remove('hidden');
    }
  }

  // Sample photo click
  photoGrid.querySelectorAll('.sample-photo').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = (btn as HTMLElement).dataset.src!;
      currentSrc = src;
      currentBase64 = ''; // Will be fetched on analyze

      // Highlight selected
      photoGrid.querySelectorAll('.sample-photo').forEach(b => {
        b.classList.remove('ring-2', 'ring-teal', 'ring-offset-2');
      });
      btn.classList.add('ring-2', 'ring-teal', 'ring-offset-2');

      // Show active area with selected image
      activeImg.src = src;
      activeArea.classList.remove('hidden');
      resultArea.classList.add('hidden');
      errorArea.classList.add('hidden');

      // Scroll to active area
      activeArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      // Start analysis immediately
      analyzePhoto();
    });
  });

  // Try another — reset to grid
  tryAnotherBtn.addEventListener('click', () => {
    resetToGrid();
    photoGrid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  // Same photo, new observation
  samePhotoBtn.addEventListener('click', () => {
    analyzePhoto();
  });

  // Error retry
  errorRetryBtn.addEventListener('click', () => {
    analyzePhoto();
  });
</script>
